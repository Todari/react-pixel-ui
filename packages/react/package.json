{
  "name": "@react-pixel-ui/react",
  "version": "2.0.4",
  "description": "Wrap any element with <Pixel> and your CSS becomes pixel art. Tailwind, inline styles, CSS modules — all supported. No Canvas, SSR compatible.",
  "keywords": [
    "react",
    "pixel",
    "pixel-art",
    "pixelated",
    "css",
    "clip-path",
    "retro",
    "ui",
    "hooks"
  ],
  "homepage": "https://github.com/Todari/react-pixel-ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Todari/react-pixel-ui.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/Todari/react-pixel-ui/issues"
  },
  "sideEffects": false,
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@react-pixel-ui/core": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@react-pixel-ui/typescript-config": "workspace:*",
    "@react-pixel-ui/eslint-config": "workspace:*",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "happy-dom": "^14.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.6.0"
  }
}
