{
  "name": "@react-pixel-ui/core",
  "version": "2.0.3",
  "description": "Core engine for @react-pixel-ui/react. Generates pixel art styles from CSS. Install @react-pixel-ui/react directly.",
  "keywords": [
    "pixel",
    "pixel-art",
    "pixelated",
    "css",
    "clip-path",
    "retro",
    "ui"
  ],
  "homepage": "https://github.com/Todari/react-pixel-ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Todari/react-pixel-ui.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/Todari/react-pixel-ui/issues"
  },
  "license": "MIT",
  "author": "Todari",
  "sideEffects": false,
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@react-pixel-ui/typescript-config": "workspace:*",
    "@react-pixel-ui/eslint-config": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.6.0"
  }
}
