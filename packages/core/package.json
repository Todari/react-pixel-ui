{
  "name": "@react-pixel-ui/core",
  "version": "2.0.2",
  "description": "CSS-based pixel art style generator using clip-path, BMP gradients, and drop-shadow. No Canvas.",
  "keywords": [
    "pixel",
    "pixel-art",
    "pixelated",
    "css",
    "clip-path",
    "retro",
    "ui"
  ],
  "homepage": "https://github.com/Todari/react-pixel-ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Todari/react-pixel-ui.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/Todari/react-pixel-ui/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@react-pixel-ui/typescript-config": "workspace:*",
    "@react-pixel-ui/eslint-config": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}